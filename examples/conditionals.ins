# If-elseif-else example
age = 20

if age < 13:
{
    print("Child")
}
elseif age < 18:
{
    print("Teenager")
}
elseif age < 65:
{
    print("Adult")
}
else:
{
    print("Senior")
}

print("---")

# Logical operators
x = 10
if x > 5 and x < 15:
{
    print("x is between 5 and 15")
}

if x > 15 or x == 10:
{
    print("x is greater than 15 or equals 10")
}
