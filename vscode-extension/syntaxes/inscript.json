{
  "scopeName": "source.inscript",
  "name": "Inscript",
  "fileTypes": ["is"],
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#number"
    },
    {
      "include": "#boolean"
    },
    {
      "include": "#keyword"
    },
    {
      "include": "#builtin"
    },
    {
      "include": "#function-def"
    },
    {
      "include": "#operator"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.inscript",
          "match": "#.*$"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.inscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.inscript",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.inscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.inscript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.inscript",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.inscript",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.inscript",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.inscript",
          "match": "\\b(if|elseif|else|while|for|in|break|continue|return|function|let|var)\\b"
        },
        {
          "name": "keyword.operator.inscript",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "builtin": {
      "patterns": [
        {
          "name": "support.function.builtin.inscript",
          "match": "\\b(print|input|length|append|insert|remove|pop|clear|copy|extend|index|slice|range|enumerate|zip|sorted|sort|reverse|reversed|unique|flatten|upper|lower|split|join|strip|replace|find|startswith|endswith|contains|isdigit|isalpha|isalnum|isspace|capitalize|title|char_at|count|repeat|slice_list|slice|abs|round|ceil|floor|min|max|sum|any|all|type|is_int|is_float|is_string|is_bool|is_list|is_dict|is_null|sqrt|sin|cos|tan|asin|acos|atan|log|log10|log2|exp|degrees|radians|gcd|factorial|pi|e|hypot|fabs|get|pop_dict|update|has_key|keys|values|read|write|append_text|readlines|file_exists|delete_file|random|randint|choice|sample|shuffle|seed|to_json|from_json|now|timestamp|year|month|day|ascii|chr|hash|id|wait|exit|hex|hex|bin|oct)\\b"
        }
      ]
    },
    "function-def": {
      "patterns": [
        {
          "name": "meta.function.inscript",
          "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "keyword.control.inscript"
            },
            "2": {
              "name": "entity.name.function.inscript"
            }
          }
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.inscript",
          "match": "[+\\-*/%]|\\*\\*"
        },
        {
          "name": "keyword.operator.comparison.inscript",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.inscript",
          "match": "="
        },
        {
          "name": "keyword.operator.logical.inscript",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.inscript",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.bracket.inscript",
          "match": "[\\[\\]{}()]"
        }
      ]
    }
  }
}
