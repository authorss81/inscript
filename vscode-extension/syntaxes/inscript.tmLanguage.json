{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "InScript",
  "scopeName": "source.inscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#decorators" },
    { "include": "#lifecycle" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.inscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.inscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.inscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.inscript", "match": "\\\\." },
            {
              "name": "meta.embedded.inscript",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin" } },
              "endCaptures":   { "0": { "name": "punctuation.definition.template-expression.end" } },
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.inscript",
          "match": "\\b(if|else|while|for|in|return|break|continue|match|try|catch|throw|await|yield)\\b"
        },
        {
          "name": "keyword.declaration.inscript",
          "match": "\\b(let|const|fn|struct|scene|ai|state|ui|btree|sync|async|import|from|export)\\b"
        },
        {
          "name": "storage.modifier.inscript",
          "match": "\\b(pub|mut|static|override|abstract|sealed|inline)\\b"
        },
        {
          "name": "constant.language.inscript",
          "match": "\\b(true|false|null|self|super)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.inscript",
          "match": "\\b(int|float|bool|string|void|never|any)\\b"
        },
        {
          "name": "support.type.builtin.inscript",
          "match": "\\b(Vec2|Vec3|Vec4|Mat4|Color|Rect|Transform|Entity|Scene|Input|Draw|Audio|Network|Physics|Time|Math|Random)\\b"
        },
        {
          "name": "entity.name.type.inscript",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.inscript",
          "match": "0[xX][0-9a-fA-F]+"
        },
        {
          "name": "constant.numeric.float.inscript",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.inscript",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.inscript",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.inscript",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.inscript",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.inscript",
          "match": "(\\+|-|\\*|/|%|\\*\\*)"
        },
        {
          "name": "keyword.operator.range.inscript",
          "match": "(\\.\\.|\\.\\.=)"
        },
        {
          "name": "keyword.operator.arrow.inscript",
          "match": "(->|=>|\\|>)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.inscript",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.method.inscript",
          "match": "(?<=\\.)([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.inscript",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.tag.inscript",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "lifecycle": {
      "patterns": [
        {
          "name": "support.function.lifecycle.inscript",
          "match": "\\b(on_start|on_update|on_draw|on_exit|on_enter|on_collision|on_click|on_key|on_connect|on_disconnect)\\b"
        }
      ]
    }
  }
}
