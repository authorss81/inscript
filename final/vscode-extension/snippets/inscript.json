{
  "Scene Declaration": {
    "prefix": "scene",
    "body": [
      "scene ${1:Main} {",
      "\tlet ${2:entity} = Entity {",
      "\t\tpos: Vec2(${3:400}, ${4:300}),",
      "\t}",
      "",
      "\ton_start {",
      "\t\t$5",
      "\t}",
      "",
      "\ton_update(dt: float) {",
      "\t\t$6",
      "\t}",
      "",
      "\ton_draw {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "InScript scene declaration"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:void} {",
      "\t$0",
      "}"
    ],
    "description": "InScript function declaration"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:Type}",
      "\t$0",
      "}"
    ],
    "description": "InScript struct declaration"
  },
  "For In": {
    "prefix": "for",
    "body": ["for ${1:item} in ${2:collection} {", "\t$0", "}"],
    "description": "For-in loop"
  },
  "While": {
    "prefix": "while",
    "body": ["while ${1:condition} {", "\t$0", "}"],
    "description": "While loop"
  },
  "If Else": {
    "prefix": "if",
    "body": ["if ${1:condition} {", "\t$2", "} else {", "\t$0", "}"],
    "description": "If-else statement"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "\t${2:pattern} => ${3:expr}",
      "\t_ => $0",
      "}"
    ],
    "description": "Match statement"
  },
  "AI State Machine": {
    "prefix": "ai",
    "body": [
      "ai ${1:Enemy} {",
      "\tstate Idle {",
      "\t\ton_update(dt) {",
      "\t\t\tif can_see(${2:player}) { switch_to(Chase) }",
      "\t\t}",
      "\t}",
      "\tstate Chase {",
      "\t\ton_update(dt) {",
      "\t\t\tnavigate_to(${2:player}.pos)",
      "\t\t\t$0",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "AI state machine"
  },
  "Behavior Tree": {
    "prefix": "btree",
    "body": [
      "btree ${1:Brain} {",
      "\tselector {",
      "\t\tsequence {",
      "\t\t\tcondition { $2 }",
      "\t\t\taction { $3 }",
      "\t\t}",
      "\t\taction { $0 }",
      "\t}",
      "}"
    ],
    "description": "Behavior tree"
  },
  "UI Screen": {
    "prefix": "ui",
    "body": [
      "ui ${1:MainMenu} {",
      "\tVStack(align: Center, gap: 20) {",
      "\t\tText(\"${2:Title}\", size: 48)",
      "\t\tButton(\"${3:Play}\", on_click: || ${4:scene.load(\"Game\")})",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "UI screen declaration"
  },
  "Network Server": {
    "prefix": "netserver",
    "body": [
      "let ${1:srv} = Network.create_server(port: ${2:7777}, max_clients: ${3:16})",
      "${1:srv}.on_connect    = |client| { $4 }",
      "${1:srv}.on_data       = |client, pkt| { ${1:srv}.broadcast(pkt) }",
      "${1:srv}.on_disconnect = |client, reason| { $0 }",
      "${1:srv}.start()"
    ],
    "description": "Network server setup"
  },
  "Sync Var": {
    "prefix": "sync",
    "body": ["sync let ${1:name}: ${2:int} = ${3:0}"],
    "description": "Synchronized variable"
  },
  "Print": {
    "prefix": "print",
    "body": ["print($0)"],
    "description": "Print statement"
  },
  "Let": {
    "prefix": "let",
    "body": ["let ${1:name} = $0"],
    "description": "Variable declaration"
  }
}
