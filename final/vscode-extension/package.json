{
  "name": "inscript-lang",
  "displayName": "InScript",
  "description": "InScript language support — syntax highlighting, snippets, run & build",
  "version": "0.5.0",
  "publisher": "inscript-lang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "inscript",
    "game",
    "scripting",
    "gamedev"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/inscript-lang/vscode-inscript"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "inscript",
        "aliases": [
          "InScript",
          "inscript"
        ],
        "extensions": [
          ".ins"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/inscript-light.svg",
          "dark": "./icons/inscript-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "inscript",
        "scopeName": "source.inscript",
        "path": "./syntaxes/inscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "inscript",
        "path": "./snippets/inscript.json"
      }
    ],
    "commands": [
      {
        "command": "inscript.run",
        "title": "InScript: Run File",
        "icon": "$(play)"
      },
      {
        "command": "inscript.check",
        "title": "InScript: Type Check"
      },
      {
        "command": "inscript.buildWeb",
        "title": "InScript: Build for Web"
      },
      {
        "command": "inscript.showAST",
        "title": "InScript: Show AST"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "inscript.run",
          "when": "resourceLangId == inscript",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "inscript.run",
        "key": "F5",
        "when": "resourceLangId == inscript"
      }
    ],
    "configuration": {
      "title": "InScript",
      "properties": {
        "inscript.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python interpreter to use for running InScript"
        },
        "inscript.showTypeHints": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred type hints as decorations"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.23.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}

